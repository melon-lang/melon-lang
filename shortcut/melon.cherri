		}
		if syscall_name.text == "is.workflow.actions.appendtofile" {
			appendToFile(syscall_arg_0, syscall_arg_1)
		}

		/* --- Control --- */

		if syscall_name.text == "is.workflow.actions.delay" {
			wait(syscall_arg_0.number)
		}

		/* --- Shortcuts --- */

		if syscall_name.text == "is.workflow.actions.runworkflow" {
			@syscall_out = run(syscall_arg_0, syscall_arg_1)
		}

		/* --- Crypto --- */

		if syscall_name.text == "is.workflow.actions.hash" {
			@syscall_out = hash(syscall_arg_0, syscall_arg_1)
		}
		if syscall_name.text == "is.workflow.actions.base64encode" {
			@syscall_out = base64Encode(syscall_arg_0)
		}
		if syscall_name.text == "is.workflow.actions.base64decode" {
			@syscall_out = base64Decode(syscall_arg_0)
		}

		/* --- Location / Weather --- */

		if syscall_name.text == "is.workflow.actions.getcurrentlocation" {
			@syscall_out = getCurrentLocation()
		}
		if syscall_name.text == "is.workflow.actions.weather.currentconditions" {
			@syscall_out = getCurrentWeather(syscall_arg_0.location)
		}
	}
	@syscall_out = base64Encode(syscall_out)
	@url = url("data:text/html;resume={image};value={syscall_out};base64,{MELON_SOURCE_CODE}")
}
