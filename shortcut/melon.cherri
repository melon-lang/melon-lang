#include 'actions/documents'
#include 'actions/shortcuts'
#include 'actions/scripting'
#include 'actions/sharing'
#include 'actions/settings'
#include 'actions/text'
#include 'actions/crypto'
#include 'actions/web'
#include 'actions/device'
#include 'actions/location'
#define color red
#define glyph timeLapse

/*
melon 🍉 Shortcut

    melon is an orthogonally persistent language designed for creating blazing fast automations for Apple devices. It uses Siri Shortcuts as a backend, but allows for more complex and performant automations to be created compared to Shortcuts application itself.

https://github.com/melon-lang/melon-lang

*/
const MELON_VERSION = "1.0.0"
const MELON_MAX_PERSISTANCE = 2147483647
const MELON_VM_STATUS_SYSCALL = "syscall"
const MELON_VM_STATUS_HALTED = "halted"
const MELON_SYSCALL_ARG_COUNTS = {
	"is.workflow.actions.showresult": 1,
	"is.workflow.actions.prompt": 1,
	"is.workflow.actions.stop": 1,
	"is.workflow.actions.alert": 2,
	"is.workflow.actions.confirm": 2,
	"is.workflow.actions.notification": 2,
	"is.workflow.actions.speaktext": 1,
	"is.workflow.actions.getclipboard": 0,
	"is.workflow.actions.setclipboard": 1,
	"is.workflow.actions.share": 1,
	"is.workflow.actions.setbrightness": 1,
	"is.workflow.actions.setvolume": 1,
	"is.workflow.actions.darkmode": 0,
	"is.workflow.actions.lightmode": 0,
	"is.workflow.actions.vibrate": 0,
	"is.workflow.actions.lock": 0,
	"is.workflow.actions.getbatterylevel": 0,
	"is.workflow.actions.getdevicedetail": 1,
	"is.workflow.actions.downloadurl": 1,
	"is.workflow.actions.openurl": 1,
	"is.workflow.actions.getwebpagecontents": 1,
	"is.workflow.actions.documentpicker.save": 2,
	"is.workflow.actions.documentpicker.open": 1,
	"is.workflow.actions.appendtofile": 2,
	"is.workflow.actions.delay": 1,
	"is.workflow.actions.runworkflow": 2,
	"is.workflow.actions.hash": 2,
	"is.workflow.actions.getcurrentlocation": 0,
	"is.workflow.actions.weather.currentconditions": 1
}
/*
Download melon source code from Github.

Currently, it downloads the source code every time you run the shortcut. There is no cache mechanism. It will be added later.
*/
const MELON_SOURCE_CODE_URL = url("http://127.0.0.1:5500/dist/webport/index.html")
const MELON_SOURCE_CODE_ = downloadURL(MELON_SOURCE_CODE_URL)
@MELON_SOURCE_CODE = MELON_SOURCE_CODE_
@MELON_SOURCE_CODE = base64Encode(MELON_SOURCE_CODE)
@code = ShortcutInput
const b64code = base64Encode(code)
@url = url("data:text/html;begin={b64code};base64,{MELON_SOURCE_CODE}")

repeat _ for MELON_MAX_PERSISTANCE {
	@response = getWebpageContents(url)
	@image = response
	
	@response = base64Decode(response)
	@response = getDictionary(response)
	
	@error = getValue(response, "error")
	@error = error.text

	if error {
		alert(error, "melon execution failed.")
		stop()
	}
	
	@status = getValue(response, "status")

	if status.text == MELON_VM_STATUS_HALTED {
		stop()
	}

	if status.text == MELON_VM_STATUS_SYSCALL {
		@syscall = getValue(response, "syscall")
		@syscall = getDictionary(syscall)
		
		@syscall_name = getValue(syscall, "name")
		@syscall_name = syscall_name.text

		@syscall_args = getValue(syscall, "argsSerialized")
		@syscall_out = ""

		/* --- Pre-extract args --- */
		@syscall_arg_count_raw = getValue(MELON_SYSCALL_ARG_COUNTS, syscall_name)
		if !syscall_arg_count_raw {
			@syscall_arg_count = 0
		} else {
			@syscall_arg_count = getNumbers(syscall_arg_count_raw)
		}

		if syscall_arg_count > 0 {
			@syscall_arg_0 = getListItem(syscall_args, 1)
		}
		if syscall_arg_count > 1 {
			@syscall_arg_1 = getListItem(syscall_args, 2)
		}

		/* --- Dispatch --- */

		if syscall_name.text == "is.workflow.actions.showresult" {
			show(syscall_arg_0.text)
		}
		if syscall_name.text == "is.workflow.actions.prompt" {
			@syscall_out = prompt(syscall_arg_0)
		}
		if syscall_name.text == "is.workflow.actions.stop" {
			output(syscall_arg_0)
		}

		/* --- UI / Notifications --- */

		if syscall_name.text == "is.workflow.actions.alert" {
			alert(syscall_arg_0, syscall_arg_1)
		}
		if syscall_name.text == "is.workflow.actions.confirm" {
			confirm(syscall_arg_0, syscall_arg_1)
		}
		if syscall_name.text == "is.workflow.actions.notification" {
			showNotification(syscall_arg_0, syscall_arg_1)
		}
		if syscall_name.text == "is.workflow.actions.speaktext" {
			speak(syscall_arg_0)
		}

		/* --- Clipboard --- */

		if syscall_name.text == "is.workflow.actions.getclipboard" {
			@syscall_out = getClipboard()
		}
		if syscall_name.text == "is.workflow.actions.setclipboard" {
			setClipboard(syscall_arg_0)
		}

		/* --- Sharing --- */

		if syscall_name.text == "is.workflow.actions.share" {
			share(syscall_arg_0)
		}

		/* --- Device Settings --- */

		if syscall_name.text == "is.workflow.actions.setbrightness" {
			setBrightness(syscall_arg_0.float)
		}
		if syscall_name.text == "is.workflow.actions.setvolume" {
			setVolume(syscall_arg_0.float)
		}
		if syscall_name.text == "is.workflow.actions.darkmode" {
			darkMode()
		}
		if syscall_name.text == "is.workflow.actions.lightmode" {
			lightMode()
		}

		/* --- Device Hardware --- */

		if syscall_name.text == "is.workflow.actions.vibrate" {
			vibrate()
		}
		if syscall_name.text == "is.workflow.actions.lock" {
			lockScreen()
		}
		if syscall_name.text == "is.workflow.actions.getbatterylevel" {
			@syscall_out = getBatteryLevel()
		}
		if syscall_name.text == "is.workflow.actions.getdevicedetail" {
			@syscall_out = getDeviceDetail(syscall_arg_0)
		}

		/* --- Web / Network --- */

		if syscall_name.text == "is.workflow.actions.downloadurl" {
			@syscall_out = downloadURL(syscall_arg_0)
		}
		if syscall_name.text == "is.workflow.actions.openurl" {
			openURL(syscall_arg_0)
		}
		if syscall_name.text == "is.workflow.actions.getwebpagecontents" {
			@syscall_out = getWebpageContents(syscall_arg_0)
		}

		/* --- Files --- */

		if syscall_name.text == "is.workflow.actions.documentpicker.save" {
			saveFile(syscall_arg_0, syscall_arg_1)
		}
		if syscall_name.text == "is.workflow.actions.documentpicker.open" {
			@syscall_out = getFile(syscall_arg_0)
		}
		if syscall_name.text == "is.workflow.actions.appendtofile" {
			appendToFile(syscall_arg_0, syscall_arg_1)
		}

		/* --- Control --- */

		if syscall_name.text == "is.workflow.actions.delay" {
			wait(syscall_arg_0.number)
		}

		/* --- Shortcuts --- */

		if syscall_name.text == "is.workflow.actions.runworkflow" {
			@syscall_out = run(syscall_arg_0, syscall_arg_1)
		}

		/* --- Crypto --- */

		if syscall_name.text == "is.workflow.actions.hash" {
			@syscall_out = hash(syscall_arg_0, syscall_arg_1)
		}

		/* --- Location / Weather --- */

		if syscall_name.text == "is.workflow.actions.getcurrentlocation" {
			@syscall_out = getCurrentLocation()
		}
		if syscall_name.text == "is.workflow.actions.weather.currentconditions" {
			@syscall_out = getCurrentWeather(syscall_arg_0)
		}
	}
	@syscall_out = base64Encode(syscall_out.text)
	@url = url("data:text/html;resume={image};value={syscall_out};base64,{MELON_SOURCE_CODE}")
}
const Text = "nil"
saveFile("", Text)
