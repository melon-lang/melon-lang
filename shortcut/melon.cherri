		}
		if syscall_name.text == "is.workflow.actions.lightmode" {
			lightMode()
		}
		if syscall_name.text == "is.workflow.actions.toggleappearance" {
			toggleAppearance()
		}
		if syscall_name.text == "is.workflow.actions.setnightshift" {
			@syscall_arg_0_bool = syscall_arg_0.text == "true"
			setNightShift(syscall_arg_0_bool)
		}
		if syscall_name.text == "is.workflow.actions.settruetone" {
			@syscall_arg_0_bool = syscall_arg_0.text == "true"
			setTrueTone(syscall_arg_0_bool)
		}
		if syscall_name.text == "is.workflow.actions.togglenightshift" {
			toggleNightShift()
		}
		if syscall_name.text == "is.workflow.actions.toggletruetone" {
			toggleTrueTone()
		}
		if syscall_name.text == "is.workflow.actions.setbluetooth" {
			@syscall_arg_0_bool = syscall_arg_0.text == "true"
			setBluetooth(syscall_arg_0_bool)
		}
		if syscall_name.text == "is.workflow.actions.setcellulardata" {
			@syscall_arg_0_bool = syscall_arg_0.text == "true"
			setCellularData(syscall_arg_0_bool)
		}
		if syscall_name.text == "is.workflow.actions.setwifi" {
			@syscall_arg_0_bool = syscall_arg_0.text == "true"
			setWifi(syscall_arg_0_bool)
		}
		if syscall_name.text == "is.workflow.actions.togglebluetooth" {
			toggleBluetooth()
		}
		if syscall_name.text == "is.workflow.actions.togglecellulardata" {
			toggleCellularData()
		}
		if syscall_name.text == "is.workflow.actions.togglewifi" {
			toggleWifi()
		}
		if syscall_name.text == "is.workflow.actions.getfocusmode" {
			@syscall_out = getFocusMode()
		}
		if syscall_name.text == "is.workflow.actions.togglednd" {
			toggleDND()
		}
		if syscall_name.text == "is.workflow.actions.dndoff" {
			DNDOff()
		}
		if syscall_name.text == "is.workflow.actions.dndon" {
			DNDOn()
		}
		if syscall_name.text == "is.workflow.actions.setwallpaper" {
			setWallpaper(syscall_arg_0)
		}
		if syscall_name.text == "is.workflow.actions.setstagemanager" {
			@syscall_arg_0_bool = syscall_arg_0.text == "true"
			@syscall_arg_1_bool = syscall_arg_1.text == "true"
			setStageManager(syscall_arg_0_bool, syscall_arg_1_bool)
		}
		if syscall_name.text == "is.workflow.actions.togglestagemanager" {
			@syscall_arg_0_bool = syscall_arg_0.text == "true"
			@syscall_arg_1_bool = syscall_arg_1.text == "true"
			toggleStageManager(syscall_arg_0_bool, syscall_arg_1_bool)
		}
		if syscall_name.text == "is.workflow.actions.getwallpaper" {
			@syscall_out = getWallpaper()
		}
		if syscall_name.text == "is.workflow.actions.getallwallpapers" {
			@syscall_out = getAllWallpapers()
		}

		/* --- Device Hardware --- */

		if syscall_name.text == "is.workflow.actions.vibrate" {
			vibrate()
		}
		if syscall_name.text == "is.workflow.actions.lock" {
			lockScreen()
		}
		if syscall_name.text == "is.workflow.actions.reboot" {
			reboot()
		}
		if syscall_name.text == "is.workflow.actions.shutdown" {
			shutdown()
		}
		if syscall_name.text == "is.workflow.actions.setairplanemode" {
			@syscall_arg_0_bool = syscall_arg_0.text == "true"
			setAirplaneMode(syscall_arg_0_bool)
		}
		if syscall_name.text == "is.workflow.actions.toggleairplanemode" {
			toggleAirplaneMode()
		}
		if syscall_name.text == "is.workflow.actions.connectedtocharger" {
			@syscall_out = connectedToCharger()
		}
		if syscall_name.text == "is.workflow.actions.ischarging" {
			@syscall_out = isCharging()
		}
		if syscall_name.text == "is.workflow.actions.getonscreencontent" {
			@syscall_out = getOnScreenContent()
		}
		if syscall_name.text == "is.workflow.actions.getorientation" {
			@syscall_out = getOrientation()
		}
		if syscall_name.text == "is.workflow.actions.getbatterylevel" {
			@syscall_out = getBatteryLevel()
		}
		if syscall_name.text == "is.workflow.actions.getdevicedetail" {
			@syscall_out = getDeviceDetail(syscall_arg_0)
		}

		/* --- Web / Network --- */

		if syscall_name.text == "is.workflow.actions.downloadurl" {
			@syscall_out = downloadURL(syscall_arg_0)
		}
		if syscall_name.text == "is.workflow.actions.openurl" {
			openURL(syscall_arg_0)
		}
		if syscall_name.text == "is.workflow.actions.getwebpagecontents" {
			@syscall_out = getWebpageContents(syscall_arg_0)
		}
		if syscall_name.text == "is.workflow.actions.getarticle" {
			@syscall_out = getArticle(syscall_arg_0)
		}
		if syscall_name.text == "is.workflow.actions.searchgiphy" {
			@syscall_out = searchGiphy(syscall_arg_0)
		}
		if syscall_name.text == "is.workflow.actions.expandurl" {
			@syscall_out = expandURL(syscall_arg_0)
		}
		if syscall_name.text == "is.workflow.actions.getcurrenturl" {
			@syscall_out = getCurrentURL()
		}
		if syscall_name.text == "is.workflow.actions.showwebpage" {
			showWebpage(syscall_arg_0)
		}
		if syscall_name.text == "is.workflow.actions.isonline" {
			@syscall_out = isOnline()
		}
		if syscall_name.text == "is.workflow.actions.connecttoserver" {
			connectToServer(syscall_arg_0.text)
		}
		if syscall_name.text == "is.workflow.actions.getrss" {
			@syscall_out = getRSS(syscall_arg_0.number, syscall_arg_1)
		}
		if syscall_name.text == "is.workflow.actions.getrssfeeds" {
			@syscall_out = getRSSFeeds(syscall_arg_0)
		}
		if syscall_name.text == "is.workflow.actions.addtoreadinglist" {
			addToReadingList(syscall_arg_0)
